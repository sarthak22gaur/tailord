# Copy to .env and edit. Loaded via `node --env-file=.env`.

# HTTP server
BRIDGE_PORT=8787
# Shared secret the extension sends in X-Bridge-Token. Generate a long random string.
BRIDGE_TOKEN=change-me-to-a-long-random-string
# Set to 1 only if you intentionally want an unauthenticated local dev bridge.
BRIDGE_ALLOW_NO_TOKEN=0
# Optional comma-separated allowlist. Extension origins are allowed automatically.
BRIDGE_ALLOWED_ORIGINS=

# Worker pool
CONCURRENCY=4
CLAUDE_TIMEOUT_MS=1800000
CLAUDE_OUTPUT_LIMIT_BYTES=2097152

# Vault root: where user data lives (master.yaml, variants, output/, jobs/).
# If unset, .resumerc.yaml in an ancestor directory is used. See the
# discovery order in tools/jd-bridge/src/config.js.
# RESUME_VAULT=/path/to/your/resume-vault

# Framework root: directory where the bridge spawns the Claude CLI so
# .claude/skills/ resolves correctly. `tailord setup-bridge` fills this in:
# packaged installs use ~/.local/share/tailord/framework, editable clones use
# the repo root.
# RESUME_FRAMEWORK=/path/to/tailord/framework-workspace

# Which runner the bridge invokes per job. `claude_cli` (default) runs the
# full tool-use pipeline (score → tailor → render PDFs). `anthropic_api`
# runs scoring only (no file writes, no PDF) — useful when the Claude CLI
# is not installed.
# MODEL_RUNNER=claude_cli

# Anthropic API runner config (only read when MODEL_RUNNER=anthropic_api).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# Claude CLI binary + flags. --dangerously-skip-permissions is required for
# headless use; there is no human to approve tool calls.
CLAUDE_BIN=claude
CLAUDE_FLAGS=--dangerously-skip-permissions --output-format=json
# Force claude to use this model on every bridge invocation, ignoring the
# CLI's own configured default. Used for both `--model` on the spawn and as
# the rate-card key in `tailord stats`. Unset to fall through to whatever
# the user's claude CLI has configured (stats will then assume Sonnet).
CLAUDE_MODEL=claude-sonnet-4-6

# Note: bridge state (SQLite job history) is stored at <vault>/.tailord/jobs.db.
# There is no DB_PATH knob — keeping state in the vault is intentional so
# job history travels with the user's data, not the framework checkout.
