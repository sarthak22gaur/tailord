{
  "manifest_version": 3,
  "name": "Tailord",
  "version": "0.1.0",
  "description": "Queue LinkedIn JDs to your local Tailord bridge for evidence-backed resume tailoring.",
  "homepage_url": "https://github.com/sarthak22gaur/tailord",
  "permissions": ["activeTab", "storage", "notifications", "alarms", "scripting"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": [
        "content/registry.js",
        "content/adapters/linkedin.js",
        "content/extract.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
